{
  "compilerOptions": {
    "target": "es2023",
    "allowJs": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": true,
    "strictNullChecks": true,
    "rootDir": "."
  },
  "include": ["./lib/**/*", "./tests/**/*"]
}
